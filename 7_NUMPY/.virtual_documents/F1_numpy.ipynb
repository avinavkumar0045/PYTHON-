import numpy as np
import time


arr = np.array([1,2,3,5,4]) #numpy array
print(arr , type(arr))


#execution time
size = 10_000_000

#python list
py_list = list(range(size))
start = time.time()
sq_list = [x**2 for x in py_list]
end = time.time()
print(f"python list time = {end-start} seconds")

#numpy arrays
np_arr = np.array(py_list)
newstart = time.time()
# vectorisation to do calc on a numpy array
sq_array = np_arr ** 2  # easy way to calc the square
newend = time.time()
print(f"Numpy array time = {newend - newstart} seconds")


#memory
import sys
print(f"python list size = {sys.getsizeof(py_list) * len(py_list)} bytes");
print(f"numpy array size = {np_arr.nbytes} bytes");



